{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.scan.usage.schema.json",
  "title": "x07.mcp.scan.usage@0.4.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool_catalog_bytes",
    "tool_catalog_est_tokens_cl100k",
    "tool_catalog_est_tokens_o200k",
    "tool_count",
    "avg_tool_description_tokens",
    "max_tool_description_tokens",
    "input_schema_bytes_total",
    "input_schema_est_tokens_total",
    "example_payload_est_tokens_total",
    "replay_transcript_est_tokens_total",
    "response_payload_est_tokens_p50",
    "response_payload_est_tokens_p95",
    "metadata_to_payload_ratio_pct",
    "requested_usage_mode",
    "usage_status",
    "usage_error_code",
    "usage_fallback_reason",
    "estimator_family",
    "estimator_version",
    "estimator_confidence"
  ],
  "properties": {
    "tool_catalog_bytes": { "type": "integer", "minimum": 0 },
    "tool_catalog_est_tokens_cl100k": { "type": "integer", "minimum": 0 },
    "tool_catalog_est_tokens_o200k": { "type": "integer", "minimum": 0 },
    "tool_count": { "type": "integer", "minimum": 0 },
    "avg_tool_description_tokens": { "type": "integer", "minimum": 0 },
    "max_tool_description_tokens": { "type": "integer", "minimum": 0 },
    "avg_tool_description_tokens_exact": { "type": ["integer", "null"], "minimum": 0 },
    "avg_tool_description_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "max_tool_description_tokens_exact": { "type": ["integer", "null"], "minimum": 0 },
    "max_tool_description_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "input_schema_bytes_total": { "type": "integer", "minimum": 0 },
    "input_schema_est_tokens_total": { "type": "integer", "minimum": 0 },
    "input_schema_tokens_exact_total": { "type": ["integer", "null"], "minimum": 0 },
    "input_schema_tokens_observed_total": { "type": ["integer", "null"], "minimum": 0 },
    "example_payload_est_tokens_total": { "type": "integer", "minimum": 0 },
    "replay_transcript_est_tokens_total": { "type": "integer", "minimum": 0 },
    "response_payload_est_tokens_p50": { "type": "integer", "minimum": 0 },
    "response_payload_est_tokens_p95": { "type": "integer", "minimum": 0 },
    "response_payload_tokens_exact_p50": { "type": ["integer", "null"], "minimum": 0 },
    "response_payload_tokens_exact_p95": { "type": ["integer", "null"], "minimum": 0 },
    "response_payload_tokens_observed_p50": { "type": ["integer", "null"], "minimum": 0 },
    "response_payload_tokens_observed_p95": { "type": ["integer", "null"], "minimum": 0 },
    "metadata_to_payload_ratio_pct": { "type": "integer", "minimum": 0 },
    "requested_usage_mode": { "type": "string", "enum": ["auto", "exact", "estimate", "observed"] },
    "usage_status": { "type": "string", "enum": ["ok", "fallback", "error"] },
    "usage_error_code": { "type": "integer", "minimum": 0 },
    "usage_fallback_reason": { "type": "string" },
    "usage_mode": {
      "type": "string",
      "enum": ["estimate", "tokenizer_exact", "trace_observed", "mixed"]
    },
    "usage_confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "tokenizer_id": { "type": ["string", "null"] },
    "trace_source": { "type": ["string", "null"] },
    "tool_catalog_tokens_exact": { "type": ["integer", "null"], "minimum": 0 },
    "tool_catalog_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "estimator_family": { "type": "string", "minLength": 1 },
    "estimator_version": { "type": "string", "minLength": 1 },
    "estimator_confidence": { "type": "string", "enum": ["low", "medium", "high"] }
  }
}
