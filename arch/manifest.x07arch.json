{
  "schema_version": "x07.arch.manifest@0.3.0",
  "repo": { "id": "hardproof", "root": "." },
  "externals": {
    "allowed_import_prefixes": ["std.", "ext.", "gen."],
    "allowed_exact": [
      "hardproof.schema.scan.dimension_coverage_v1",
      "hardproof.schema.scan.dimension_manifest_v1",
      "hardproof.schema.scan.report_manifest_v1",
      "hardproof.schema.scan.target_ref_v1"
    ]
  },
  "nodes": [
    {
      "id": "score_core",
      "match": { "module_prefixes": [], "path_globs": ["score_core/src/**/*.x07.json"] },
      "world": "solve-pure",
      "trust_zone": "verified_core",
      "visibility": { "mode": "public", "visible_to": [] },
      "imports": { "deny_prefixes": ["std.os.", "ext."], "allow_prefixes": ["scan", "std."] }
    },
    {
      "id": "score_core_tests",
      "match": { "module_prefixes": [], "path_globs": ["score_core/tests/**/*.x07.json"] },
      "world": "solve-pure",
      "trust_zone": "test_only",
      "visibility": { "mode": "restricted", "visible_to": [] },
      "imports": { "deny_prefixes": ["std.os.", "ext."], "allow_prefixes": ["scan", "tests", "std."] }
    },
    {
      "id": "cli_os",
      "match": { "module_prefixes": [], "path_globs": ["cli/src/**/*.x07.json"] },
      "world": "run-os",
      "trust_zone": "untrusted",
      "visibility": { "mode": "public", "visible_to": [] },
      "imports": { "deny_prefixes": [], "allow_prefixes": [] }
    },
    {
      "id": "cli_helper_tests",
      "match": { "module_prefixes": [], "path_globs": ["tests/**/*.x07.json"] },
      "world": "run-os",
      "trust_zone": "test_only",
      "visibility": { "mode": "restricted", "visible_to": [] },
      "imports": { "deny_prefixes": ["std.os."], "allow_prefixes": ["scan", "std.", "ext.", "tests.", "util"] }
    }
  ],
  "rules": [
    { "kind": "deny_cycles_v1", "id": "deny_cycles.nodes_v1", "scope": "nodes" }
  ],
  "checks": {
    "deny_cycles": true,
    "deny_orphans": true,
    "enforce_visibility": false,
    "enforce_world_caps": true,
    "brand_boundary_v1": { "enabled": false }
  },
  "tool_budgets": {
    "max_modules": 2000,
    "max_edges": 20000,
    "max_diags": 2000,
    "contracts_budgets": { "max_contract_files": 2000, "max_contract_bytes": 67108864 }
  },
  "contracts_v1": {
    "sm": {
      "index_path": "arch/sm/index.x07sm.json",
      "gen_dir": "cli/src/gen/sm",
      "require_gen_uptodate": true
    },
    "budgets": {
      "index_path": "arch/budgets/index.x07budgets.json",
      "gen_dir": "arch/budgets/gen",
      "require_scopes": false
    },
    "canonical_json": { "mode": "jcs_rfc8785_v1" }
  }
}
